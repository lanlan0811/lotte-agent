{
  "name": "lotte-agent",
  "version": "0.1.0",
  "description": "Lotte - 多渠道通用智能体平台，具备自动化和编程开发能力",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lotte": "dist/entry.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch src/entry.ts",
    "start": "node dist/entry.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "chatbot",
    "mcp",
    "multi-channel"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "ws": "^8.18.0",
    "undici": "^7.0.0",
    "openai": "^4.70.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "@lydell/node-pty": "1.2.0-beta.12",
    "playwright-core": "^1.50.0",
    "sharp": "^0.33.0",
    "file-type": "^19.0.0",
    "jszip": "^3.10.0",
    "@pierre/diffs": "^1.1.0",
    "pdfjs-dist": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "qrcode-terminal": "^0.12.0",
    "gray-matter": "^4.0.0",
    "js-yaml": "^4.1.0",
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.0",
    "chokidar": "^4.0.0",
    "json5": "^2.2.0",
    "croner": "^9.0.0",
    "nodemailer": "^6.9.0",
    "screenshot-desktop": "^1.15.0",
    "fluent-ffmpeg": "^2.1.0",
    "markdown-it": "^14.0.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsdown": "^0.21.0",
    "tsx": "^4.21.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/ws": "^8.5.0",
    "@types/js-yaml": "^4.0.0",
    "@types/nodemailer": "^6.4.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
